# Shared monitor environment.
# Copy to ~/.validator-monitor.env on the validator host and fill in local values.
# Do not commit real webhook URLs, bot tokens, private keys, mnemonics, or wallet files.

# Optional Discord webhook fallbacks. Prefer chain-specific webhooks.
DISCORD_WEBHOOK=
COSMOS_DISCORD_WEBHOOK_URL=
COSMOS_MAINNET_DISCORD_WEBHOOK_URL=
COSMOS_TESTNET_DISCORD_WEBHOOK_URL=
COSMOS_MAINNET_GOV_DISCORD_WEBHOOK_URL=
COSMOS_TESTNET_GOV_DISCORD_WEBHOOK_URL=

# Cosmos Hub mainnet.
COSMOS_MAINNET_CHAIN_ID=cosmoshub-4
COSMOS_MAINNET_SERVICE=gaiad-mainnet
COSMOS_MAINNET_BIN=/home/YOUR_USER/go/bin/gaiad-mainnet
COSMOS_MAINNET_HOME=/home/YOUR_USER/.gaia-mainnet
COSMOS_MAINNET_RPC=http://127.0.0.1:26657
COSMOS_MAINNET_NODE=tcp://127.0.0.1:26657
COSMOS_MAINNET_QUERY_NODE=tcp://127.0.0.1:26657
COSMOS_MAINNET_VALOPER=REPLACE_WITH_MAINNET_VALOPER
COSMOS_MAINNET_OPERATOR_ADDRESS=REPLACE_WITH_MAINNET_OPERATOR_ADDRESS
COSMOS_MAINNET_LEDGER_ADDRESS=REPLACE_WITH_MAINNET_PAYMENT_ADDRESS
COSMOS_MAINNET_GOV_VOTER_ADDRESS=REPLACE_WITH_MAINNET_OPERATOR_ADDRESS
COSMOS_MAINNET_GOV_KEY_NAME=YOUR_MAINNET_KEY_NAME
COSMOS_MAINNET_MIN_PEERS=5
COSMOS_MAINNET_MAX_MISSED_BLOCKS=10

# Cosmos provider testnet.
# Defaults assume this testnet node is the only Cosmos node using local CometBFT RPC.
# If you run mainnet and testnet on the same host, set these to your alternate testnet port, for example 26667.
COSMOS_TESTNET_CHAIN_ID=provider
COSMOS_TESTNET_SERVICE=gaiad
COSMOS_TESTNET_BIN=/home/YOUR_USER/go/bin/gaiad
COSMOS_TESTNET_HOME=/home/YOUR_USER/.gaia
COSMOS_TESTNET_RPC=http://127.0.0.1:26657
COSMOS_TESTNET_NODE=tcp://127.0.0.1:26657
COSMOS_TESTNET_QUERY_NODE=tcp://127.0.0.1:26657
COSMOS_TESTNET_VALOPER=REPLACE_WITH_TESTNET_VALOPER
COSMOS_TESTNET_WALLET_ADDRESS=REPLACE_WITH_TESTNET_WALLET_ADDRESS
COSMOS_TESTNET_VALCONS=REPLACE_WITH_TESTNET_VALCONS
COSMOS_TESTNET_GOV_VOTER_ADDRESS=REPLACE_WITH_TESTNET_WALLET_ADDRESS
COSMOS_TESTNET_GOV_KEY_NAME=YOUR_TESTNET_KEY_NAME
COSMOS_TESTNET_MIN_PEERS=5
COSMOS_TESTNET_MAX_MISSED_BLOCKS=8000
